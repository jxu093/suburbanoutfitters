# Example environment variables (safe to commit)
# Copy this to .env.local and add your real API keys

# For Expo, use EXPO_PUBLIC_ prefix for client-side access
EXPO_PUBLIC_WEATHER_API_KEY=YOUR_OPENWEATHERMAP_API_KEY_HERE

# Claude API key for AI features (get one at https://console.anthropic.com)
EXPO_PUBLIC_CLAUDE_API_KEY=YOUR_CLAUDE_API_KEY_HERE
